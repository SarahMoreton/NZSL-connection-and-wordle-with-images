<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>NZSL Connection + Wordle Game</title>
<style>
/* GENERAL STYLES */
body {
  font-family: Arial, sans-serif;
  background: #f9f9f9;
  color: #222;
  text-align: center;
  margin: 0;
  padding: 20px;
}

/* MODE TOGGLE */
.mode-toggle button {
  margin: 5px;
  padding: 10px 20px;
  font-size: 16px;
  cursor: pointer;
}

/* CONNECTIONS GRID */
.connections-grid {
  display: grid;
  gap: 20px;
  justify-content: center;
  margin: 20px auto;
}
.tile {
  width: 120px;
  height: 120px;
  border: 4px solid #333;
  border-radius: 12px;
  background: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
}
.tile-img {
  width: 80%;
}

/* GROUP COLORS */
.correct-group-1 { background: #d4edda; }
.correct-group-2 { background: #cce5ff; }
.correct-group-3 { background: #fff3cd; }
.correct-group-4 { background: #f8d7da; }

/* WORDLE */
.wordle-container {
  display: flex;
  gap: 40px;
  justify-content: center;
  flex-wrap: wrap;
}
#grid {
  display: grid;
  gap: 10px;
}
.tile-wordle {
  width: 80px;
  height: 80px;
  border: 3px solid #333;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 16px;
}
#word-bank {
  display: grid;
  grid-template-columns: repeat(2, 120px);
  gap: 15px;
}
.word-option {
  border: 3px solid #444;
  padding: 10px;
  cursor: pointer;
  text-align: center;
}
.word-option img, .word-option video {
  width: 100%;
  border-radius: 8px;
}
.fs-letter {
  width: 40px;
  height: 40px;
  margin: 2px;
}

/* CONTROLS */
.controls, .tile-selector {
  margin-top: 20px;
}
.controls button, .tile-selector button {
  margin: 5px;
  padding: 8px 16px;
  font-size: 14px;
  cursor: pointer;
}
</style>
</head>
<body>

<h1>NZSL Connection & Wordle Game</h1>

<!-- MODE TOGGLE -->
<div class="mode-toggle">
  <button onclick="showConnections()">Connections</button>
  <button onclick="showWordle()">NZSL Wordle</button>
</div>

<!-- TILE NUMBER SELECTOR -->
<div class="tile-selector">
  <label>Tiles per round:</label>
  <button onclick="setTileCount(12)">12</button>
  <button onclick="setTileCount(16)">16</button>
  <button onclick="setTileCount(20)">20</button>
</div>

<!-- CONNECTIONS BOARD -->
<div id="connections-game">
  <div class="connections-grid" id="connections-grid"></div>
</div>

<!-- WORDLE BOARD -->
<div id="wordle-game" style="display:none;">
  <h2>NZSL Wordle</h2>

  <!-- Mode -->
  <div class="modes">
    <button onclick="setMode('support')">Visual Support</button>
    <button onclick="setMode('visual')">Visual Only</button>
    <button onclick="setMode('challenge')">Challenge</button>
  </div>

  <div class="wordle-container">
    <!-- Guess Grid -->
    <div id="grid"></div>

    <!-- Word Bank -->
    <div id="word-bank"></div>
  </div>

  <div class="controls">
    <button onclick="giveHint()">Hint</button>
    <button onclick="revealWord()">Reveal</button>
    <button onclick="resetWordle()">Reset</button>
  </div>
</div>

<script>
// GLOBALS
let tileCount = 16;
let currentMode = 'support';
let currentWord = null;
let guessAttempts = 0;
const maxAttempts = 6;

// FULL NZSL WORD LIST - 50 WORDS
const words = [
  { word: "DOG", category: "animal", image: "images/dog.jpg", video: "videos/dog.mp4" },
  { word: "CAT", category: "animal", image: "images/cat.jpg", video: "videos/cat.mp4" },
  { word: "BIRD", category: "animal", image: "images/bird.jpg", video: "videos/bird.mp4" },
  { word: "FISH", category: "animal", image: "images/fish.jpg", video: "videos/fish.mp4" },
  { word: "COW", category: "animal", image: "images/cow.jpg", video: "videos/cow.mp4" },
  { word: "EAT", category: "action", image: "images/eat.jpg", video: "videos/eat.mp4" },
  { word: "DRINK", category: "action", image: "images/drink.jpg", video: "videos/drink.mp4" },
  { word: "RUN", category: "action", image: "images/run.jpg", video: "videos/run.mp4" },
  { word: "JUMP", category: "action", image: "images/jump.jpg", video: "videos/jump.mp4" },
  { word: "SLEEP", category: "action", image: "images/sleep.jpg", video: "videos/sleep.mp4" },
  { word: "HAPPY", category: "feeling", image: "images/happy.jpg", video: "videos/happy.mp4" },
  { word: "SAD", category: "feeling", image: "images/sad.jpg", video: "videos/sad.mp4" },
  { word: "ANGRY", category: "feeling", image: "images/angry.jpg", video: "videos/angry.mp4" },
  { word: "TIRED", category: "feeling", image: "images/tired.jpg", video: "videos/tired.mp4" },
  { word: "STOP", category: "command", image: "images/stop.jpg", video: "videos/stop.mp4" },
  { word: "GO", category: "command", image: "images/go.jpg", video: "videos/go.mp4" },
  { word: "PLEASE", category: "polite", image: "images/please.jpg", video: "videos/please.mp4" },
  { word: "THANKYOU", category: "polite", image: "images/thankyou.jpg", video: "videos/thankyou.mp4" },
  { word: "SORRY", category: "polite", image: "images/sorry.jpg", video: "videos/sorry.mp4" },
  { word: "HELLO", category: "greeting", image: "images/hello.jpg", video: "videos/hello.mp4" },
  { word: "GOODBYE", category: "greeting", image: "images/goodbye.jpg", video: "videos/goodbye.mp4" },
  { word: "SCHOOL", category: "place", image: "images/school.jpg", video: "videos/school.mp4" },
  { word: "TEACHER", category: "person", image: "images/teacher.jpg", video: "videos/teacher.mp4" },
  { word: "STUDENT", category: "person", image: "images/student.jpg", video: "videos/student.mp4" },
  { word: "FRIEND", category: "person", image: "images/friend.jpg", video: "videos/friend.mp4" },
  { word: "FAMILY", category: "people", image: "images/family.jpg", video: "videos/family.mp4" },
  { word: "MOTHER", category: "people", image: "images/mother.jpg", video: "videos/mother.mp4" },
  { word: "FATHER", category: "people", image: "images/father.jpg", video: "videos/father.mp4" },
  { word: "SISTER", category: "people", image: "images/sister.jpg", video: "videos/sister.mp4" },
  { word: "BROTHER", category: "people", image: "images/brother.jpg", video: "videos/brother.mp4" },
  { word: "BOOK", category: "object", image: "images/book.jpg", video: "videos/book.mp4" },
  { word: "PEN", category: "object", image: "images/pen.jpg", video: "videos/pen.mp4" },
  { word: "CHAIR", category: "object", image: "images/chair.jpg", video: "videos/chair.mp4" },
  { word: "TABLE", category: "object", image: "images/table.jpg", video: "videos/table.mp4" },
  { word: "FOOD", category: "concept", image: "images/food.jpg", video: "videos/food.mp4" },
  { word: "WATER", category: "concept", image: "images/water.jpg", video: "videos/water.mp4" },
  { word: "FRUIT", category: "concept", image: "images/fruit.jpg", video: "videos/fruit.mp4" },
  { word: "APPLE", category: "food", image: "images/apple.jpg", video: "videos/apple.mp4" },
  { word: "ORANGE", category: "food", image: "images/orange.jpg", video: "videos/orange.mp4" },
  { word: "COLD", category: "descriptor", image: "images/cold.jpg", video: "videos/cold.mp4" },
  { word: "HOT", category: "descriptor", image: "images/hot.jpg", video: "videos/hot.mp4" },
  { word: "BIG", category: "descriptor", image: "images/big.jpg", video: "videos/big.mp4" },
  { word: "SMALL", category: "descriptor", image: "images/small.jpg", video: "videos/small.mp4" },
  { word: "MORE", category: "quantifier", image: "images/more.jpg", video: "videos/more.mp4" },
  { word: "LESS", category: "quantifier", image: "images/less.jpg", video: "videos/less.mp4" },
  { word: "WHERE", category: "question", image: "images/where.jpg", video: "videos/where.mp4" },
  { word: "WHO", category: "question", image: "images/who.jpg", video: "videos/who.mp4" },
  { word: "WHAT", category: "question", image: "images/what.jpg", video: "videos/what.mp4" },
  { word: "WHEN", category: "question", image: "images/when.jpg", video: "videos/when.mp4" },
  { word: "WHY", category: "question", image: "images/why.jpg", video: "videos/why.mp4" }
];

// ---------------- CONNECTIONS -----------------
function showConnections(){
  document.getElementById('connections-game').style.display='block';
  document.getElementById('wordle-game').style.display='none';
  startConnections();
}

function startConnections() {
  const grid = document.getElementById('connections-grid');
  const gridSize = Math.sqrt(tileCount);
  grid.style.gridTemplateColumns = `repeat(${gridSize}, 120px)`;
  grid.innerHTML = '';
  for (let i=0; i<tileCount; i++){
    const tile = document.createElement('div');
    tile.className = 'tile';
    const item = words[i % words.length];
    tile.innerHTML = `<img src="${item.image}" class="tile-img"/>`;
    grid.appendChild(tile);
  }
}

// ---------------- WORDLE -----------------
function showWordle(){
  document.getElementById('connections-game').style.display='none';
  document.getElementById('wordle-game').style.display='block';
  startWordle();
}

// TILE COUNT
function setTileCount(num){
  tileCount = num;
  showConnections();
}

// MODE
function setMode(mode){
  currentMode = mode;
  loadWordBank();
}

// FINGERSPELLING FUNCTION
function getFingerspelling(word){
  return word.split("").map(letter=>{
    return `<img src="images/fingerspelling/${letter.toUpperCase()}.jpg" class="fs-letter">`;
  }).join('');
}

// WORDLE FUNCTIONS
function startWordle(){
  guessAttempts = 0;
  currentWord = words[Math.floor(Math.random()*words.length)];
  loadGuessGrid();
  loadWordBank();
}

function loadGuessGrid(){
  const grid = document.getElementById('grid');
  grid.innerHTML = '';
  for(let i=0;i<maxAttempts;i++){
    const row = document.createElement('div');
    row.style.display='flex';
    for(let j=0;j<currentWord.word.length;j++){
      const tile = document.createElement('div');
      tile.className='tile-wordle';
      row.appendChild(tile);
    }
    grid.appendChild(row);
  }
}

function loadWordBank(){
  const bank = document.getElementById('word-bank');
  bank.innerHTML = '';
  words.forEach(w=>{
    const div = document.createElement('div');
    div.className = 'word-option';
    if (currentMode === 'visual') {
      div.innerHTML = `<video src="${w.video}" muted loop class="sign-video"></video>`;
    } else {
      div.innerHTML = `<video src="${w.video}" muted loop class="sign-video"></video>
                       <p>${w.word}</p>`;
    }
    div.onmouseenter = () => div.querySelector('video').play();
    div.onmouseleave = () => div.querySelector('video').pause();
    div.onclick = () => selectWord(w.word);
    bank.appendChild(div);
  });
}

function selectWord(word){
  const grid = document.getElementById('grid');
  const row = grid.children[guessAttempts];
  for(let i=0;i<word.length;i++){
    row.children[i].innerHTML = getFingerspelling(word[i]);
    if(word[i] === currentWord.word[i]){
      row.children[i].style.background = '#d4edda';
    } else if(currentWord.word.includes(word[i])){
      row.children[i].style.background = '#fff3cd';
    } else {
      row.children[i].style.background = '#f8d7da';
    }
  }
  guessAttempts++;
}

function giveHint(){
  alert('Category: ' + currentWord.category);
}

function revealWord(){
  alert('Word: ' + currentWord.word);
}

function resetWordle(){
  startWordle();
}

// INITIAL LOAD
startConnections();
</script>

</body>
</html>
